# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Allowed CORS origin (your Next.js frontend URL)
CORS_ORIGIN=http://localhost:3001

# Node environment
NODE_ENV=development

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Google Gemini API key — obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
